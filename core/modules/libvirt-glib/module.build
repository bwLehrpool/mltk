#!/bin/bash
fetch_source() {
	autoclone
}

build() {
	local SRCDIR="${MODULE_WORK_DIR}/src/libvirt-glib"
	cde "${SRCDIR}"

	meson setup \
		--prefix="/usr" \
		--sysconfdir="/etc" \
		--libexecdir="/usr/libexec" \
		--localstatedir="/var" \
		build \
		-Dtests=disabled \
		-Ddocs=disabled || perror "'meson' failed."
	ninja -v -C build || perror "'ninja' failed."
	ninja -v -C build install || perror "'ninja install' failed."
}

post_copy() {
	:
}
