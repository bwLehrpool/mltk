#!/bin/bash
fetch_source() {
	autoclone
}

build() {
	local SRCDIR="${MODULE_WORK_DIR}/src/libvirt-python"
	cde "${SRCDIR}"

	python3 setup.py build || perror "'setup.py build' failed."
	python3 setup.py install \
		--prefix "/usr" \
		--install-layout "deb" \
		--install-lib "/usr/lib/python3/dist-packages" || perror "'setup.py install' failed."

	rm -rf -- "/usr/lib/python3/dist-packages/__pycache__"
}

post_copy() {
	:
}
