#!/bin/bash
fetch_source() {
	autoclone
}

build() {
	local SRCDIR="${MODULE_WORK_DIR}/src/libvirt-python"
	cde "${SRCDIR}"

	python3 -m pip install . --prefix=/usr --no-build-isolation --root-user-action=ignore \
		|| perror "Cannot pip install libvirt-python"

	rm -rf -- "/usr/lib/python3/dist-packages/__pycache__"
}

post_copy() {
	:
}
