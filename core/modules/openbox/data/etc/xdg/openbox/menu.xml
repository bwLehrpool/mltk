<?xml version="1.0" encoding="UTF-8"?>

<openbox_menu xmlns="http://openbox.org/"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://openbox.org/
                file:///usr/share/openbox/menu.xsd">

<menu id="root-menu" label="Openbox 3">
  <item label="Terminal">
    <action name="Execute"><execute>slxterm</execute></action>
  </item>
  <item label="vmChooser">
    <action name="Execute"><execute>vmchooser</execute></action>
  </item>
  <!-- This requires the presence of the 'menu' package to work -->
  <menu id="/Debian" />
  <separator />
  <menu id="client-list-menu" />
  <separator />
  <item label="Restart">
    <action name="Restart" />
  </item>
  <separator />
  <item label="Exit">
    <action name="Exit" />
  </item>
</menu>

<menu id="my-client-menu">
  <item label="Restore"><action name="Unshade"/></item>
  <item label="Move"><action name="Move"/></item>
  <item label="Resize"><action name="Resize"/></item>
  <item label="Iconify"><action name="Iconify"/></item>
  <item label="Maximize"><action name="Maximize"/></item>
  <!-- Shade would normally be here; leaving it out removes it -->
  <separator/>
  <item label="Close"><action name="Close"/></item>
</menu>

</openbox_menu>
